NODE_ENV=development

PROJECT_NAME=myCubeKub
API_PORT=3000
DOCS_PORT=3001
ALLOWED_ORIGINS=http://localhost:5173

DATABASE_URL=postgres://postgres:postgres@localhost:5432/mycubekub_db
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me
JWT_EXPIRES_IN_HOURS=24
ENABLE_PASSWORD_HASH_ENDPOINT=false

READINESS_ENABLED=false
READINESS_ALLOW_DEGRADED=true
READINESS_MAX_WAIT_MS=30000
READINESS_INTERVAL_MS=2000

SWAGGER_ENABLED=true
SWAGGER_SERVER_URL=/
PUBLIC_FILE_BASE_URL=http://localhost:5173

CLIENT_GUARD_ENABLED=false
CLIENT_ID=
CLIENT_SIGNING_SECRET=
CLIENT_SIGNATURE_TOLERANCE_SEC=300

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOG_EXCEEDED=true
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=300
RATE_LIMIT_AUTH_ENABLED=true
RATE_LIMIT_AUTH_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_FILES_WINDOW_MS=60000
RATE_LIMIT_FILES_MAX=120
RATE_LIMIT_EXPENSIVE_WINDOW_MS=60000
RATE_LIMIT_EXPENSIVE_MAX=30
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=120
RATE_LIMIT_NOTIFICATIONS_WINDOW_MS=60000
RATE_LIMIT_NOTIFICATIONS_MAX=60
RATE_LIMIT_PROFILE_WINDOW_MS=60000
RATE_LIMIT_PROFILE_MAX=60
RATE_LIMIT_ADMIN_WINDOW_MS=60000
RATE_LIMIT_ADMIN_MAX=60
RATE_LIMIT_RESPONDER_WINDOW_MS=60000
RATE_LIMIT_RESPONDER_MAX=60

SERVERS_DIR=./servers
HOST_SERVERS_DIR=

DOCKER_BIN=
DOCKER_SOCKET_PATH=
# Optional alternative to DOCKER_SOCKET_PATH, for example unix:///var/run/docker.sock
DOCKER_HOST=

CONNECTION_IP=localhost

# Cache TTLs (seconds)
CACHE_TTL_HEALTH_SEC=5
CACHE_TTL_AUTH_SESSION_SEC=300
CACHE_TTL_SERVER_LIST_SEC=10
CACHE_TTL_SERVER_DETAIL_SEC=10
CACHE_TTL_SERVER_STATS_SEC=3
CACHE_TTL_SERVER_PROPERTIES_SEC=30
CACHE_TTL_FILES_LIST_SEC=15
CACHE_TTL_FILE_CONTENT_SEC=15
