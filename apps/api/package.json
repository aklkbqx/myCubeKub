{
  "name": "@mycubekub/api",
  "private": true,
  "version": "2.4.3",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "docker:push": "node scripts/docker-push.js",
    "docker:push:major": "node scripts/docker-push.js major",
    "docker:push:minor": "node scripts/docker-push.js minor",
    "docker:push:patch": "node scripts/docker-push.js patch"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "dockerode": "^4.0.0",
    "drizzle-orm": "^0.38.0",
    "elysia": "^1.2.0",
    "ioredis": "^5.10.0",
    "postgres": "^3.4.0",
    "rate-limiter-flexible": "^9.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dockerode": "^3.3.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
